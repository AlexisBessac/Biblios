{% extends 'base.html.twig' %}

{% block title %}Catalogue des livres{% endblock %}

{% block body %}
<main class="main">
    <section class=" container py-5">
        <h1 class="text-center my-4">Catalogue des livres</h1>
        <a href="{{ path('app_home') }}" class="btn btn-outline-primary my-4" title="Revenir à la page d'accueil">Revenir à la page d'accueil</a>
        <div class="px-4 px-lg-5 mt-5">
            <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">
                {% for book in books %}
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">{{ book.name }}</h5>
                            <p class="card-text">
                                {{ book.author.name }}
                            </p>
                            <a href="{{ path('app_book_show', { 'id': book.id }) }}">
                                <button class="btn btn-outline-primary flex-shrink-0" type="button" title="Voir">
                                    <twig:ux:icon name="typcn:arrow-back" width="24px" height="24px" />
                                    Voir
                                </button>
                            </a>
                        </div>
                    </div>
                {% else %}
                    <p>Aucun enregistrement dans la base de données.</p>
                {% endfor %}
            </div>
        </div>
    </section>
</main>
{% endblock %}
