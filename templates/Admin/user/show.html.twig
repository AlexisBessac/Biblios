{% extends 'base.html.twig' %}

{% block title %}{{user.firstname}} {{user.lastname}}{% endblock %}

{% block body %}
<main class="main">
    <section class="container py-5">
        <h1 class="text-center my-4">{{user.firstname}} {{user.lastname}}</h1>

        <a href="{{ path('app_admin_user_index') }}" class="btn btn-outline-primary my-4"
            title="Revenir à la liste des utilisateurs">Revenir à la liste des utilisateurs</a>


        <table class="table table-striped table-bordered my-4">
            <tbody>
                <tr>
                    <th>Email</th>
                    <td>{{ user.email }}</td>
                </tr>
                <tr>
                    <th>Roles</th>
                    <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
                </tr>
            </tbody>
        </table>


        {{ include('admin/user/_delete_form.html.twig') }}
    </section>
</main>
{% endblock %}