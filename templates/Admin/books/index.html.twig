{% extends 'base.html.twig' %}

{% block title %}Books index{% endblock %}

{% block body %}
    <h1>Books index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Description</th>
                <th>Nombre de pages</th>
                <th>Date de publication</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                <td>{{ book.name }}</td>
                <td>{{ book.description }}</td>
                <td>{{ book.pageNumber }}</td>
                <td>{{ book.publishedAt ? book.publishedAt|date('Y') : '' }}</td>
                <td>
                    <a href="{{ path('app_admin_books_show', {'id': book.id}) }}">show</a>
                    <a href="{{ path('app_admin_books_edit', {'id': book.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_admin_books_new') }}">Create new</a>
{% endblock %}
