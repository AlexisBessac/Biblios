<form method="post" action="{{ path('app_admin_books_delete', {'id': book.id}) }}" onsubmit="return confirm('Etes vous sûr de vouloir supprimer ce livre ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
    <button class="btn btn-outline-danger" title="Supprimer">Suppimer</button>
</form>
