{% extends 'base.html.twig' %}

{% block title %}Liste des genres{% endblock %}

{% block body %}
<main class="main">
    <section class="container py-5">
        <h1 class="text-center my-4">Liste des genres</h1>

        <a href="{{ path('app_admin_genre_new') }}" class="btn btn-outline-primary" title="créer un nouveau genre">Créer un nouveau genre</a>
    
        <table class="table table-striped table-bordered my-4">
            <thead>
                <tr>
                    <th>Nom du genre</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for genre in genres %}
                <tr>
                    <td>{{ genre.name }}</td>
                    <td>
                        <a href="{{ path('app_admin_genre_show', {'id': genre.id}) }}" class="btn btn-outline-primary mx-2" title="Détail">Détail</a>
                        <a href="{{ path('app_admin_genre_edit', {'id': genre.id}) }}" class="btn btn-outline-success" title="Modifier">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="2">Aucun genre trouvé dans la base de données</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</main>

{% endblock %}
