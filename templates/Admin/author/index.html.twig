{% extends 'base.html.twig' %}

{% block title %}Liste des auteurs{% endblock %}

{% block body %}
<main class="main">
    <section class="container py-5">
        <h1 class="text-center my-4">Liste des auteurs</h1>

        <a href="{{ path('app_admin_author_new') }}" class="btn btn-outline-primary my-4" title="Créer un nouvel auteur">Créer un nouvel auteur</a>
    
        <table class="table table-striped table-bordered my-4">
            <thead>
                <tr>
                    <th>Nom et prénom de l'auteur</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for author in authors %}
                <tr>
                    <td>{{ author.name }}</td>
                    <td>
                        <a href="{{ path('app_admin_author_show', {'id': author.id}) }}" class="btn btn-outline-primary mx-2" title="Détail">Détail</a>
                        <a href="{{ path('app_admin_author_edit', {'id': author.id}) }}" class="btn btn-outline-success" title="Modifier">Modifier</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="2">Aucun auteur trouvé dans la base de données</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </section>
</main>

{% endblock %}
