{% extends 'base.html.twig' %}

{% block title %}Voir le détail{% endblock %}

{% block body %}
<main>
    <section class="container py-5 my-4">
        <h1 class="text-center my-4">{{user.firstname}} {{user.lastname}}</h1>
    
        <a href="{{ path('app_admin_user_index') }}" class="btn btn-outline-dark my-4" title="Revenir à la liste">Revenir à
            la liste</a>
    
        <table class="table table-striped table-bordered my-4">
            <tbody>
                <tr>
                    <th>Email</th>
                    <td>{{ user.email }}</td>
                </tr>
                <tr>
                    <th>Rôles</th>
                    <td>
                        {% if user.roles and user.roles|length > 0 %}
                        {{ user.roles|join(', ') }}
                        {% else %}
                        Aucun rôle attribué.
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Prénom</th>
                    <td>{{ user.firstname }}</td>
                </tr>
                <tr>
                    <th>Nom</th>
                    <td>{{ user.lastname }}</td>
                </tr>
            </tbody>
        </table>
    
        {{ include('admin/user/_delete_form.html.twig') }}
    </section>
</main>
{% endblock %}