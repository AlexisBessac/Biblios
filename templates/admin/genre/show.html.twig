{% extends 'base.html.twig' %}

{% block title %}{{genre.name}}{% endblock %}

{% block body %}
<main>
    <section class="container py-5">
        <h1 class="text-center py-4">{{genre.name}}</h1>

        <a href="{{ path('app_admin_genre_index') }}" class="btn btn-outline-dark my-4" title="Retour à la liste">Retour
            à la liste</a>


        <table class="table table-striped table-bordered my-4">
            <tbody>
                <tr>
                    <th>Id</th>
                    <td>{{ genre.id }}</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>{{ genre.name }}</td>
                </tr>
            </tbody>
        </table>

        {{ include('admin/genre/_delete_form.html.twig') }}
    </section>
</main>
{% endblock %}