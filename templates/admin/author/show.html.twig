        <h1 class="text-center my-4">{{author.name}}</h1>

    <a href="{{ path('app_admin_author_index') }}" class="btn btn-outline-dark my-4" title="Revenir à la liste">Revenir à la liste</a>

    <table class="table table-borderd table-striped my-4">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ author.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ author.name }}</td>
            </tr>
        </tbody>
    </table>

    {{ include('admin/author/_delete_form.html.twig') }}
    </section>
{% endblock %}
