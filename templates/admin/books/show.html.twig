{% extends 'base.html.twig' %}

{% block title %}Détail d'un livre{% endblock %}

{% block body %}
<section class="container py-5">
    <h1 class="text-center my-4">{{book.title}}</h1>

    <a href="{{ path('app_admin_books_index') }}" class="btn btn-outline-dark my-4" title="Revenir à la liste">Revenir à la liste</a>


    <table class="table table-striped table-bordered my-2">
        <tbody>
            <tr>
                <th>Titre</th>
                <td>{{ book.title }}</td>
            </tr>
            <tr>
                <th>Date de publication</th>
                <td>{{ book.publishedAt ? book.publishedAt|date('Y') : '' }}</td>
            </tr>
            <tr>
                <th>Nombre de pages</th>
                <td>{{ book.pageNumber }}</td>
            </tr>
        </tbody>
    </table>

    {{ include('admin/books/_delete_form.html.twig') }}
</section>
{% endblock %}
