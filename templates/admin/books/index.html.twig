{% extends 'base.html.twig' %}

{% block title %}Liste des Livres{% endblock %}

{% block body %}
    <section class="container py-5 my-4">
        <h1 class="text-center my-4">Liste des livres</h1>

        <a href="{{ path('app_admin_books_new') }}" class="btn btn-primary" title="Créer un nouveau livre">Créer un nouveau livre</a>


    <table class="table table-striped table-bordered my-4 mw-auto">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Date de publication</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                <td><i>{{ book.title }}</i></td>
                <td>{{ book.publishedAt ? book.publishedAt|date('Y') : '' }}</td>
                <td>
                    <a href="{{ path('app_admin_books_show', {'id': book.id}) }}" class="btn btn-outline-primary mx-2" title="Voir le détail">Voir le détail</a>
                    <a href="{{ path('app_admin_books_edit', {'id': book.id}) }}" class="btn btn-outline-success" title="Modifier">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Aucun livre trouvé dans la base de données</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    </section>
{% endblock %}
